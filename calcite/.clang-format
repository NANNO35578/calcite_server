---
# ============================================
# 语言设置
# ============================================
Language: Cpp  # 目标语言：C++


# ============================================
# 基础风格模板
# ============================================
# BasedOnStyle: LLVM
# 可选值：
# - LLVM       : LLVM 项目风格（默认）
# - Google     : Google C++ 风格
# - Chromium   : Chromium 项目风格
# - Mozilla    : Mozilla 风格
# - WebKit     : WebKit 风格
# - Microsoft  : Microsoft 风格
# - GNU        : GNU 风格
# - None       : 不从任何风格继承，完全自定义
# 作用：继承指定风格的所有默认值，之后可以覆盖特定选项


# ============================================
# 访问修饰符缩进
# ============================================
AccessModifierOffset: -2
# 可选值：任意整数（正数向右缩进，负数向左缩进）
# 作用：控制 public:/protected:/private: 相对于类定义的缩进
# -2 表示向左缩进 2 格，通常与 IndentWidth: 2 配合使修饰符与 class 对齐


# ============================================
# 开括号后的对齐方式
# ============================================
AlignAfterOpenBracket: Align
# 可选值：
# - Align      : 对齐括号内的参数
# - DontAlign  : 不对齐，使用 ContinuationIndentWidth 缩进
# - AlwaysBreak: 总是换行
# 作用：控制函数调用、函数声明等开括号后的对齐行为


# ============================================
# 结构体数组对齐
# ============================================
AlignArrayOfStructures: None
# 可选值：
# - None       : 不对齐
# - Left       : 左对齐
# - Right      : 右对齐
# 作用：控制结构体数组初始化时的列对齐，如：
# struct Foo { int a; int b; };
# Foo arr[] = { {1, 2}, {3, 4} };


# ============================================
# 连续宏定义对齐
# ============================================
AlignConsecutiveMacros: None
# 可选值：
# - None       : 不对齐
# - Consecutive: 仅对齐连续的宏
# - AcrossEmptyLines: 跨空行对齐
# - AcrossComments : 跨注释对齐
# - AcrossEmptyLinesAndComments: 跨空行和注释对齐
# 作用：控制连续 #define 宏的对齐


# ============================================
# 连续赋值对齐
# ============================================
AlignConsecutiveAssignments: None
# 可选值：同 AlignConsecutiveMacros
# 作用：控制连续赋值语句的等号对齐，如：
# int    a    = 1;
# double long = 2;


# ============================================
# 连续位域对齐
# ============================================
AlignConsecutiveBitFields: None
# 可选值：同 AlignConsecutiveMacros
# 作用：控制连续位域声明的对齐


# ============================================
# 连续声明对齐
# ============================================
AlignConsecutiveDeclarations: None
# 可选值：同 AlignConsecutiveMacros
# 作用：控制连续声明的对齐，如变量名、函数名对齐


# ============================================
# 转义换行符对齐
# ============================================
AlignEscapedNewlines: Right
# 可选值：
# - DontAlign  : 不对齐
# - Left       : 左对齐（行首）
# - Right      : 右对齐（行尾，在列限制之前）
# 作用：控制宏定义中反斜杠续行符的位置


# ============================================
# 操作数对齐
# ============================================
AlignOperands: Align
# 可选值：
# - DontAlign  : 不对齐
# - Align      : 对齐操作数
# - AlignAfterOperator: 对齐操作符后的操作数
# 作用：控制多行表达式中操作数的对齐方式


# ============================================
# 行尾注释对齐
# ============================================
AlignTrailingComments: true
# 可选值：true / false
# 作用：是否对齐行尾注释


# ============================================
# 参数换行控制
# ============================================
AllowAllArgumentsOnNextLine: true
# 可选值：true / false
# 作用：是否允许函数调用的所有参数放在下一行

AllowAllParametersOfDeclarationOnNextLine: true
# 可选值：true / false
# 作用：是否允许函数声明的所有参数放在下一行


# ============================================
# 短枚举单行
# ============================================
AllowShortEnumsOnASingleLine: true
# 可选值：true / false
# 作用：是否允许短枚举定义在一行内，如：enum { A, B, C };


# ============================================
# 短代码块单行
# ============================================
AllowShortBlocksOnASingleLine: Never
# 可选值：
# - Never      : 从不（总是换行）
# - Empty      : 仅空块
# - Always     : 总是允许
# 作用：控制短代码块（如 {}）是否单行


# ============================================
# 短 case 标签单行
# ============================================
AllowShortCaseLabelsOnASingleLine: false
# 可选值：true / false
# 作用：是否允许短 case 标签与代码同一行


# ============================================
# 短函数单行
# ============================================
AllowShortFunctionsOnASingleLine: All
# 可选值：
# - None       : 从不
# - InlineOnly : 仅内联函数
# - Empty      : 仅空函数体
# - Inline     : 类内定义的函数
# - All        : 所有短函数
# 作用：控制短函数的格式化方式


# ============================================
# 短 Lambda 单行
# ============================================
AllowShortLambdasOnASingleLine: All
# 可选值：
# - None       : 从不
# - Empty      : 仅空函数体
# - Inline     : 作为参数传递的 Lambda
# - All        : 所有短 Lambda
# 作用：控制短 Lambda 是否单行，如：[] { return 0; }


# ============================================
# 短 if 语句单行
# ============================================
AllowShortIfStatementsOnASingleLine: Never
# 可选值：
# - Never       : 从不
# - WithoutElse : 没有 else 时允许
# - OnlyFirstIf : 仅在第一个 if 允许
# - AllIfsAndElse: 所有 if/else 都允许
# 作用：控制短 if 语句是否单行


# ============================================
# 短循环单行
# ============================================
AllowShortLoopsOnASingleLine: false
# 可选值：true / false
# 作用：是否允许短循环（for/while）单行


# ============================================
# 返回类型换行（旧选项）
# ============================================
AlwaysBreakAfterDefinitionReturnType: None
# 可选值：
# - None       : 不断行
# - All        : 总是断行
# - TopLevel   : 仅在顶层函数
# - AllDefinitions: 所有定义
# - TopLevelDefinitions: 顶层定义
# 作用：控制函数定义返回类型后的换行（已弃用，用 AlwaysBreakAfterReturnType）

AlwaysBreakAfterReturnType: None
# 可选值：同上
# 作用：控制函数返回类型后的换行行为


# ============================================
# 多行字符串前换行
# ============================================
AlwaysBreakBeforeMultilineStrings: false
# 可选值：true / false
# 作用：是否在多行字符串字面量前强制换行


# ============================================
# 模板声明换行
# ============================================
AlwaysBreakTemplateDeclarations: MultiLine
# 可选值：
# - No         : 从不（除非超出列限制）
# - MultiLine  : 多行参数时换行
# - Yes        : 总是换行
# 作用：控制 template<...> 是否单独一行


# ============================================
# 属性宏列表
# ============================================
AttributeMacros:
  - __capability
# 可选值：宏名称列表
# 作用：指定作为属性的宏，格式化时会特殊处理


# ============================================
# 参数打包
# ============================================
BinPackArguments: true
# 可选值：true / false
# 作用：是否将函数参数打包到尽可能少的行

BinPackParameters: true
# 可选值：true / false
# 作用：是否将函数形参打包到尽可能少的行


# ============================================
# 大括号换行配置
# ============================================
BraceWrapping:
  AfterCaseLabel: false        # case 标签后是否换行
  AfterClass: false            # class 后是否换行
  AfterControlStatement: Never # 控制语句后换行（if/for/while/switch）
                               # 可选：Never, MultiLine, Always
  AfterEnum: false             # enum 后是否换行
  AfterFunction: false         # 函数后是否换行
  AfterNamespace: false        # namespace 后是否换行
  AfterObjCDeclaration: false  # Objective-C 声明后
  AfterStruct: false           # struct 后是否换行
  AfterUnion: false            # union 后是否换行
  AfterExternBlock: false      # extern 块后是否换行
  BeforeCatch: false           # catch 前是否换行
  BeforeElse: false            # else 前是否换行
  BeforeLambdaBody: false      # Lambda 体前是否换行
  BeforeWhile: false           # do-while 的 while 前是否换行
  IndentBraces: false          # 是否缩进大括号（K&R 风格 vs Allman 风格）
  SplitEmptyFunction: true     # 空函数是否分行写 {}
  SplitEmptyRecord: true       # 空类/结构体是否分行写 {}
  SplitEmptyNamespace: true    # 空 namespace 是否分行写 {}


# ============================================
# 二元运算符前换行
# ============================================
BreakBeforeBinaryOperators: None
# 可选值：
# - None       : 在运算符后换行
# - NonAssignment: 非赋值运算符前换行
# - All        : 所有运算符前换行
# 作用：控制长表达式中换行的位置


# ============================================
# 概念声明前换行
# ============================================
BreakBeforeConceptDeclarations: true
# 可选值：true / false
# 作用：C++20 concept 声明是否总是在 template 后换行


# ============================================
# 大括号前换行
# ============================================
BreakBeforeBraces: Attach
# 可选值：
# - Attach     : 大括号紧跟前面（K&R 风格）
# - Linux      : 除函数外都紧跟（Linux 内核风格）
# - Mozilla    : 类/函数换行，控制语句紧跟
# - Stroustrup : 除函数和类外都紧跟
# - Allman     : 总是换行（Allman 风格）
# - GNU        : 除控制语句外都换行，且缩进
# - WebKit     : 函数换行，其他紧跟
# - Custom     : 使用 BraceWrapping 自定义
# 作用：控制大括号的位置风格


# ============================================
# 继承列表换行
# ============================================
BreakBeforeInheritanceComma: false
# 可选值：true / false
# 作用：是否在继承列表逗号前换行（已弃用，用 BreakInheritanceList）

BreakInheritanceList: BeforeColon
# 可选值：
# - BeforeColon: 冒号前换行
# - BeforeComma: 逗号前换行
# - AfterColon : 冒号后换行
# 作用：控制类继承列表的换行方式


# ============================================
# 三元运算符换行
# ============================================
BreakBeforeTernaryOperators: true
# 可选值：true / false
# 作用：三元运算符 ? : 是否在 ? 前换行


# ============================================
# 构造函数初始化列表换行
# ============================================
BreakConstructorInitializersBeforeComma: false
# 可选值：true / false
# 作用：是否在逗号前换行（已弃用，用 BreakConstructorInitializers）

BreakConstructorInitializers: BeforeColon
# 可选值：
# - BeforeColon: 冒号前换行
# - BeforeComma: 逗号前换行
# - AfterColon : 冒号后换行
# 作用：控制构造函数初始化列表的换行


# ============================================
# Java 字段注解换行
# ============================================
BreakAfterJavaFieldAnnotations: false
# 可选值：true / false
# 作用：Java 字段注解后是否换行（C++ 配置中无影响）


# ============================================
# 字符串字面量换行
# ============================================
BreakStringLiterals: true
# 可选值：true / false
# 作用：是否允许在字符串字面量中间自动换行（使用 \ 续行）


# ============================================
# 列限制
# ============================================
ColumnLimit: 80
# 可选值：整数（0 表示无限制）
# 作用：代码的最大列宽，超出则尝试换行


# ============================================
# 注释杂注
# ============================================
CommentPragmas: '^ IWYU pragma:'
# 可选值：正则表达式
# 作用：匹配特定格式的注释，格式化时保留这些注释不变


# ============================================
# 限定词对齐
# ============================================
QualifierAlignment: Leave
# 可选值：
# - Leave      : 保持原样
# - Left       : const int x（左对齐）
# - Right      : int const x（右对齐）
# - Custom     : 使用 QualifierOrder 自定义顺序
# 作用：控制 const/volatile 等限定词的位置


# ============================================
# 紧凑命名空间
# ============================================
CompactNamespaces: false
# 可选值：true / false
# 作用：是否将短命名空间合并到一行，如：namespace a { namespace b {


# ============================================
# 构造函数初始化缩进
# ============================================
ConstructorInitializerIndentWidth: 4
# 可选值：整数
# 作用：构造函数初始化列表的缩进宽度


# ============================================
# 续行缩进
# ============================================
ContinuationIndentWidth: 4
# 可选值：整数（0 表示与行首对齐）
# 作用：续行的缩进宽度（函数参数、模板参数等换行后的缩进）


# ============================================
# C++11 列表初始化风格
# ============================================
Cpp11BracedListStyle: true
# 可选值：true / false
# 作用：是否使用 C++11 风格的列表初始化（空格处理不同）
# true:  vector<int> x{1, 2, 3};    // 紧贴
# false: vector<int> x{ 1, 2, 3 };  // 有空格


# ============================================
# 派生换行符
# ============================================
DeriveLineEnding: true
# 可选值：true / false
# 作用：是否从输入文件自动检测换行符风格（\n vs \r\n）


# ============================================
# 派生指针对齐
# ============================================
DerivePointerAlignment: false
# 可选值：true / false
# 作用：是否从输入文件自动检测指针对齐方式（int* p vs int *p）


# ============================================
# 禁用格式化
# ============================================
DisableFormat: false
# 可选值：true / false
# 作用：设置为 true 时完全禁用格式化（用于调试）


# ============================================
# 访问修饰符后空行
# ============================================
EmptyLineAfterAccessModifier: Never
# 可选值：
# - Never      : 从不
# - Leave      : 保持原样
# - Always     : 总是
# 作用：访问修饰符（public:/private:）后是否加空行


# ============================================
# 访问修饰符前空行
# ============================================
EmptyLineBeforeAccessModifier: LogicalBlock
# 可选值：
# - Never      : 从不
# - Leave      : 保持原样
# - LogicalBlock: 逻辑块前（类定义内部）
# - Always     : 总是
# 作用：访问修饰符前是否加空行


# ============================================
# 自动检测打包
# ============================================
ExperimentalAutoDetectBinPacking: false
# 可选值：true / false
# 作用：实验性功能，自动检测代码中的 BinPack 风格


# ============================================
# 构造函数初始化打包
# ============================================
PackConstructorInitializers: BinPack
# 可选值：
# - BinPack    : 尽可能打包到少行
# - CurrentLine: 当前行尽可能多
# - NextLine   : 每个初始化项一行
# - Never      : 总是每行一个
# 作用：控制构造函数初始化列表的打包方式

BasedOnStyle: ''  # 空字符串，不使用基础风格
ConstructorInitializerAllOnOneLineOrOnePerLine: false  # 是否严格单行或单每行
AllowAllConstructorInitializersOnNextLine: true        # 是否允许全放下一行


# ============================================
# 修复命名空间注释
# ============================================
FixNamespaceComments: true
# 可选值：true / false
# 作用：是否自动添加/修复命名空间结束注释，如：} // namespace foo


# ============================================
# 循环宏
# ============================================
ForEachMacros:
  - foreach
  - Q_FOREACH
  - BOOST_FOREACH
# 可选值：宏名称列表
# 作用：指定类似 for 的宏，格式化时按 for 循环处理


# ============================================
# 条件宏
# ============================================
IfMacros:
  - KJ_IF_MAYBE
# 可选值：宏名称列表
# 作用：指定类似 if 的宏，格式化时按 if 语句处理


# ============================================
# Include 块排序
# ============================================
IncludeBlocks: Preserve
# 可选值：
# - Preserve   : 保持原样
# - Merge      : 合并并排序
# - Regroup    : 重新分组并排序
# 作用：控制 #include 块的分组和排序行为


# ============================================
# Include 分类
# ============================================
IncludeCategories:
  # 第一类：LLVM/Clang 头文件
  - Regex: '^"(llvm|llvm-c|clang|clang-c)/'
    Priority: 2        # 优先级（数字越小越靠前）
    SortPriority: 0    # 排序优先级（0 表示使用 Priority）
    CaseSensitive: false  # 正则是否区分大小写
  
  # 第二类：第三方库头文件
  - Regex: '^(<|"(gtest|gmock|isl|json)/)'
    Priority: 3
  
  # 第三类：其他所有头文件
  - Regex: '.*'
    Priority: 1
# 作用：定义不同头文件的分组和排序规则


# ============================================
# 主文件正则
# ============================================
IncludeIsMainRegex: '(Test)?$'
# 可选值：正则表达式
# 作用：识别主文件的正则，如 foo.cc 对应 foo.h

IncludeIsMainSourceRegex: ''
# 可选值：正则表达式
# 作用：识别主源文件的正则


# ============================================
# 访问修饰符缩进
# ============================================
IndentAccessModifiers: false
# 可选值：true / false
# 作用：访问修饰符是否额外缩进（与 AccessModifierOffset 配合）


# ============================================
# case 标签缩进
# ============================================
IndentCaseLabels: false
# 可选值：true / false
# 作用：case 标签是否缩进（相对于 switch）

IndentCaseBlocks: false
# 可选值：true / false
# 作用：case 块（{}）是否缩进


# ============================================
# goto 标签缩进
# ============================================
IndentGotoLabels: true
# 可选值：true / false
# 作用：goto 标签是否缩进（false 则靠左对齐）


# ============================================
# 预处理器指令缩进
# ============================================
IndentPPDirectives: None
# 可选值：
# - None       : 不缩进
# - AfterHash  : # 后缩进
# - BeforeHash : # 前缩进
# 作用：控制 #if/#ifdef 等预处理指令的缩进


# ============================================
# extern 块缩进
# ============================================
IndentExternBlock: AfterExternBlock
# 可选值：
# - AfterExternBlock: extern "C" 后缩进内容
# - NoIndent   : 不缩进
# - Indent     : 缩进（包括 extern 本身）
# 作用：控制 extern "C" { } 块的缩进


# ============================================
# requires 子句缩进（C++20）
# ============================================
IndentRequires: false
# 可选值：true / false
# 作用：requires 子句是否缩进


# ============================================
# 缩进宽度
# ============================================
IndentWidth: 2
# 可选值：正整数
# 作用：每次缩进的空格数


# ============================================
# 函数名换行缩进
# ============================================
IndentWrappedFunctionNames: false
# 可选值：true / false
# 作用：长函数名换行后是否缩进


# ============================================
# 尾随逗号插入
# ============================================
InsertTrailingCommas: None
# 可选值：
# - None       : 不插入
# - Wrapped    : 仅换行时插入
# 作用：是否在参数列表末尾自动插入逗号（便于 git diff）


# ============================================
# JavaScript 引号
# ============================================
JavaScriptQuotes: Leave
# 可选值：
# - Leave      : 保持原样
# - Single     : 单引号
# - Double     : 双引号
# 作用：JavaScript 字符串引号风格


# ============================================
# JavaScript 导入换行
# ============================================
JavaScriptWrapImports: true
# 可选值：true / false
# 作用：JavaScript 导入是否换行


# ============================================
# 保持块开头空行
# ============================================
KeepEmptyLinesAtTheStartOfBlocks: true
# 可选值：true / false
# 作用：是否保留块开头的空行


# ============================================
# Lambda 体缩进
# ============================================
LambdaBodyIndentation: Signature
# 可选值：
# - Signature  : 与 Lambda 签名对齐（即与 [ 对齐）
# - OuterScope : 与外部作用域对齐
# 作用：控制 Lambda 函数体的缩进基准


# ============================================
# 宏块标记
# ============================================
MacroBlockBegin: ''
MacroBlockEnd: ''
# 可选值：宏名称
# 作用：标记宏定义块的开始和结束，格式化时按块处理


# ============================================
# 最大连续空行
# ============================================
MaxEmptyLinesToKeep: 1
# 可选值：非负整数
# 作用：最多保留的连续空行数


# ============================================
# 命名空间缩进
# ============================================
NamespaceIndentation: None
# 可选值：
# - None       : 不缩进
# - Inner      : 仅缩进内部内容
# - All        : 全部缩进
# 作用：namespace { } 内的代码是否缩进


# ============================================
# Objective-C 协议列表打包
# ============================================
ObjCBinPackProtocolList: Auto
# 可选值：
# - Auto       : 自动判断
# - Always     : 总是打包
# - Never      : 从不打包
# 作用：Objective-C 协议列表的打包行为


# ============================================
# Objective-C 块缩进
# ============================================
ObjCBlockIndentWidth: 2
# 可选值：整数
# 作用：Objective-C 块的缩进宽度


# ============================================
# Objective-C 嵌套块换行
# ============================================
ObjCBreakBeforeNestedBlockParam: true
# 可选值：true / false
# 作用：嵌套块参数前是否换行


# ============================================
# Objective-C 属性空格
# ============================================
ObjCSpaceAfterProperty: false
# 可选值：true / false
# 作用：@property 后是否有空格

ObjCSpaceBeforeProtocolList: true
# 可选值：true / false
# 作用：协议列表前是否有空格


# ============================================
# 换行惩罚值（越小越倾向于换行）
# ============================================
PenaltyBreakAssignment: 2           # 赋值运算换行惩罚
PenaltyBreakBeforeFirstCallParameter: 19  # 第一个参数前换行惩罚
PenaltyBreakComment: 300            # 注释内换行惩罚（很大，尽量不打破注释）
PenaltyBreakFirstLessLess: 120      # << 前换行惩罚（流操作）
PenaltyBreakOpenParenthesis: 0      # ( 前换行惩罚
PenaltyBreakString: 1000            # 字符串内换行惩罚（极大）
PenaltyBreakTemplateDeclaration: 10 # 模板声明换行惩罚
PenaltyExcessCharacter: 1000000     # 超出行限制惩罚（极大）
PenaltyReturnTypeOnItsOwnLine: 60   # 返回类型单独一行惩罚
PenaltyIndentedWhitespace: 0        # 缩进空白惩罚


# ============================================
# 指针对齐
# ============================================
PointerAlignment: Right
# 可选值：
# - Left       : int* p（靠左）
# - Right      : int *p（靠右）
# - Middle     : int * p（中间，不推荐）
# 作用：指针/引用符号的位置


# ============================================
# 预处理器缩进宽度
# ============================================
PPIndentWidth: -1
# 可选值：整数（-1 表示使用 IndentWidth）
# 作用：预处理器指令的缩进宽度


# ============================================
# 引用对齐
# ============================================
ReferenceAlignment: Pointer
# 可选值：
# - Pointer    : 跟随 PointerAlignment
# - Left       : int& x
# - Right      : int &x
# - Middle     : int & x
# 作用：引用符号的位置


# ============================================
# 重新排版注释
# ============================================
ReflowComments: true
# 可选值：true / false
# 作用：是否自动重新排版注释（调整换行）


# ============================================
# 移除 LLVM 风格大括号
# ============================================
RemoveBracesLLVM: false
# 可选值：true / false
# 作用：是否移除 LLVM 风格中可选的大括号（if 单语句等）


# ============================================
# 分离定义块
# ============================================
SeparateDefinitionBlocks: Leave
# 可选值：
# - Leave      : 保持原样
# - Always     : 总是分离（类/函数间加空行）
# - Never      : 从不分离
# 作用：是否在类定义、函数定义之间加空行


# ============================================
# 短命名空间行数
# ============================================
ShortNamespaceLines: 1
# 可选值：非负整数
# 作用：短于该值的命名空间可以紧凑显示（配合 CompactNamespaces）


# ============================================
# Include 排序
# ============================================
SortIncludes: CaseSensitive
# 可选值：
# - Never      : 不排序
# - CaseSensitive: 区分大小写排序
# - CaseInsensitive: 不区分大小写排序
# 作用：是否对 #include 排序


# ============================================
# Java 静态导入排序
# ============================================
SortJavaStaticImport: Before
# 可选值：
# - Before     : 静态导入在前
# - After      : 静态导入在后
# 作用：Java 静态导入的排序位置


# ============================================
# using 声明排序
# ============================================
SortUsingDeclarations: true
# 可选值：true / false / LexicographicNumeric（数字友好排序）
# 作用：是否对 using 声明排序


# ============================================
# C 风格转换后空格
# ============================================
SpaceAfterCStyleCast: false
# 可选值：true / false
# 作用：C 风格转换后是否有空格，如：(int) x vs (int)x


# ============================================
# 逻辑非后空格
# ============================================
SpaceAfterLogicalNot: false
# 可选值：true / false
# 作用：! 后是否有空格，如：! x vs !x


# ============================================
# 模板关键字后空格
# ============================================
SpaceAfterTemplateKeyword: true
# 可选值：true / false
# 作用：template 后是否有空格，如：template <int> vs template<int>


# ============================================
# 赋值运算符前空格
# ============================================
SpaceBeforeAssignmentOperators: true
# 可选值：true / false
# 作用：= += 等赋值运算符前是否有空格


# ============================================
# case 冒号前空格
# ============================================
SpaceBeforeCaseColon: false
# 可选值：true / false
# 作用：case 标签的冒号前是否有空格，如：case 1 : vs case 1:


# ============================================
# C++11 列表前空格
# ============================================
SpaceBeforeCpp11BracedList: false
# 可选值：true / false
# 作用：C++11 列表初始化前是否有空格，如：vector<int> {} vs vector<int>{}


# ============================================
# 构造函数初始化冒号前空格
# ============================================
SpaceBeforeCtorInitializerColon: true
# 可选值：true / false
# 作用：构造函数初始化列表冒号前是否有空格


# ============================================
# 继承冒号前空格
# ============================================
SpaceBeforeInheritanceColon: true
# 可选值：true / false
# 作用：继承列表冒号前是否有空格


# ============================================
# 括号前空格
# ============================================
SpaceBeforeParens: ControlStatements
# 可选值：
# - Never      : 从不
# - ControlStatements: 控制语句后（if/for/while...）
# - Always     : 总是
# - NonEmptyParentheses: 非空括号前
# - Custom     : 使用 SpaceBeforeParensOptions 自定义

SpaceBeforeParensOptions:
  AfterControlStatements: true      # 控制语句后
  AfterForeachMacros: true          # foreach 宏后
  AfterFunctionDefinitionName: false # 函数定义名后
  AfterFunctionDeclarationName: false # 函数声明名后
  AfterIfMacros: true               # if 宏后
  AfterOverloadedOperator: false    # 重载运算符后
  BeforeNonEmptyParentheses: false  # 非空括号前


# ============================================
# 指针限定词周围空格
# ============================================
SpaceAroundPointerQualifiers: Default
# 可选值：
# - Default    : 默认行为
# - Before     : 限定词前
# - After      : 限定词后
# - Both       : 前后都有
# 作用：控制 const int* const 中第二个 const 周围的空格


# ============================================
# 范围 for 冒号前空格
# ============================================
SpaceBeforeRangeBasedForLoopColon: true
# 可选值：true / false
# 作用：范围 for 循环的冒号前是否有空格，如：for (auto x : vec)


# ============================================
# 空块内空格
# ============================================
SpaceInEmptyBlock: false
# 可选值：true / false
# 作用：空块 {} 内是否有空格，如：{} vs { }


# ============================================
# 空括号内空格
# ============================================
SpaceInEmptyParentheses: false
# 可选值：true / false
# 作用：空括号 () 内是否有空格，如：() vs ( )


# ============================================
# 行尾注释前空格
# ============================================
SpacesBeforeTrailingComments: 1
# 可选值：正整数
# 作用：行尾注释 // 前的空格数


# ============================================
# 尖括号内空格
# ============================================
SpacesInAngles: Never
# 可选值：
# - Never      : 从不
# - Always     : 总是
# - Leave      : 保持原样（实验性）
# 作用：模板参数尖括号内是否有空格，如：vector< int >


# ============================================
# 条件语句内空格
# ============================================
SpacesInConditionalStatement: false
# 可选值：true / false
# 作用：条件语句括号内是否有空格，如：if ( x ) vs if (x)


# ============================================
# 容器字面量空格
# ============================================
SpacesInContainerLiterals: true
# 可选值：true / false
# 作用：容器字面量内是否有空格，如：{ 1, 2 } vs {1, 2}


# ============================================
# C 风格转换括号内空格
# ============================================
SpacesInCStyleCastParentheses: false
# 可选值：true / false
# 作用：C 风格转换括号内是否有空格，如：( int )x vs (int)x


# ============================================
# 行注释前缀空格
# ============================================
SpacesInLineCommentPrefix:
  Minimum: 1    # 最小空格数
  Maximum: -1   # 最大空格数（-1 表示无限制）
# 作用：// 注释后内容的空格数控制


# ============================================
# 圆括号内空格
# ============================================
SpacesInParentheses: false
# 可选值：true / false
# 作用：圆括号内是否有空格，如：( x ) vs (x)


# ============================================
# 方括号内空格
# ============================================
SpacesInSquareBrackets: false
# 可选值：true / false
# 作用：数组/下标括号内是否有空格，如：a[ 0 ] vs a[0]


# ============================================
# 方括号前空格
# ============================================
SpaceBeforeSquareBrackets: false
# 可选值：true / false
# 作用：数组名与 [ 之间是否有空格，如：a [0] vs a[0]


# ============================================
# 位域冒号间距
# ============================================
BitFieldColonSpacing: Both
# 可选值：
# - None       : 无空格
# - Before     : 冒号前
# - After      : 冒号后
# - Both       : 前后都有
# 作用：位域声明中冒号的空格，如：int a : 2 vs int a:2


# ============================================
# C++ 标准
# ============================================
Standard: Latest
# 可选值：
# - Cpp03      : C++03
# - Cpp11      : C++11
# - Cpp14      : C++14
# - Cpp17      : C++17
# - Cpp20      : C++20
# - Latest     : 最新标准
# - Auto       : 自动检测
# 作用：根据标准确定支持的语法特性


# ============================================
# 类似属性的宏
# ============================================
StatementAttributeLikeMacros:
  - Q_EMIT
# 可选值：宏名称列表
# 作用：看起来像语句属性的宏


# ============================================
# 语句宏
# ============================================
StatementMacros:
  - Q_UNUSED
  - QT_REQUIRE_VERSION
# 可选值：宏名称列表
# 作用：完整的语句宏，格式化时按语句处理


# ============================================
# Tab 宽度
# ============================================
TabWidth: 8
# 可选值：正整数
# 作用：显示时一个 Tab 的等效空格数（实际仍使用空格，除非 UseTab: true）


# ============================================
# 使用 CRLF
# ============================================
UseCRLF: false
# 可选值：true / false
# 作用：是否使用 Windows 换行符（\r\n），false 使用 Unix 换行符（\n）


# ============================================
# 使用 Tab
# ============================================
UseTab: Never
# 可选值：
# - Never      : 从不，使用空格
# - ForIndentation: 仅缩进使用
# - ForContinuationAndIndentation: 续行和缩进
# - AlignWithSpaces: 对齐用空格，缩进用 Tab
# - Always     : 总是使用
# 作用：是否使用 Tab 字符代替空格


# ============================================
# 空白敏感宏
# ============================================
WhitespaceSensitiveMacros:
  - STRINGIZE
  - PP_STRINGIZE
  - BOOST_PP_STRINGIZE
  - NS_SWIFT_NAME
  - CF_SWIFT_NAME
# 可选值：宏名称列表
# 作用：这些宏内部空白敏感，格式化时不改变其内部空格

